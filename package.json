{
  "name": "un-pas-apres-l-autre",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "content:index": "node scripts/generate-articles-index.mjs",
    "content:sitemap": "node scripts/generate-sitemap.mjs",
    "prestart": "npm run content:index",
    "prebuild": "npm run content:index && npm run content:sitemap",
    "serve:ssr:un-pas-apres-l-autre": "node dist/un-pas-apres-l-autre/server/server.mjs",
    "lint": "ng lint",
    "storybook": "ng run un-pas-apres-l-autre:storybook",
    "build-storybook": "ng run un-pas-apres-l-autre:build-storybook"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.4",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.1",
    "express": "^5.1.0",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.1",
    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@netlify/angular-runtime": "^4.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8",
    "storybook": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-devkit/architect": "^0.2100.0",
    "@angular-devkit/core": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@compodoc/compodoc": "^1.2.1",
    "eslint-plugin-storybook": "^10.4.6"
  }
}
